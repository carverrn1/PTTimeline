# =============================================================================
# PTTimeline .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# -----------------------------------------------------------------------------
# PyInstaller build artifacts
# -----------------------------------------------------------------------------
build/
dist/

# -----------------------------------------------------------------------------
# Inno Setup installer output
# -----------------------------------------------------------------------------
Installer/

# -----------------------------------------------------------------------------
# My Claude Project Files staging folder
# -----------------------------------------------------------------------------
Claude_Project_Files/

# -----------------------------------------------------------------------------
# Notepad++ backup folders (appear in any subfolder)
# -----------------------------------------------------------------------------
**/nppBackup/

# -----------------------------------------------------------------------------
# Backup and temporary files
# -----------------------------------------------------------------------------
*.bak
*.out
*.log
* - Copy*.*

# -----------------------------------------------------------------------------
# Archive files
# -----------------------------------------------------------------------------
*.7z
*.zip

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
# VS Code
.vscode/

# PyCharm
.idea/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
filelist.txt
*.npp_session
