# =============================================================================
# PTTimeline .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Virtual environment
# -----------------------------------------------------------------------------
.venv/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc

# -----------------------------------------------------------------------------
# PyInstaller build artifacts
# -----------------------------------------------------------------------------
build/
dist/

# -----------------------------------------------------------------------------
# Inno Setup installer output
# -----------------------------------------------------------------------------
Installer/

# -----------------------------------------------------------------------------
# My Claude Project Files staging folder
# -----------------------------------------------------------------------------
Claude_Project_Files/

# -----------------------------------------------------------------------------
# Notepad++ session files and backup folders (appear in any subfolder)
# -----------------------------------------------------------------------------
*.npp_session
**/nppBackup/

# -----------------------------------------------------------------------------
# Backup and temporary files/folders
# -----------------------------------------------------------------------------
*.bak
*.out
*.log
* - Copy*.*
files/
**/ptt_backups/

# -----------------------------------------------------------------------------
# Archive files
# -----------------------------------------------------------------------------
*.7z
*.zip

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
# VS Code
.vscode/

# PyCharm
.idea/

# -----------------------------------------------------------------------------
# Miscellaneous/Delvelopment artificats
# -----------------------------------------------------------------------------
filelist.txt
*.lnk
PTTimeline_Issues.md
test_samples/